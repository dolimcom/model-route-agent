### Context routing: establish CODING as the previous task
# This request calls the configured coding model once and persists the route.
POST {{baseUrl}}/api/agent/chat
Content-Type: application/json

{
  "question": "分析一个 Spring Boot 服务启动后立即退出的常见原因。",
  "conversationId": "{{contextConversationId}}"
}

### Context routing: context-dependent GENERAL-like wording inherits CODING
# Expected: taskType=CODING, modelId=coding, reason starts with "Context-aware router inherited"
POST {{baseUrl}}/api/agent/route
Content-Type: application/json

{
  "question": "所以你有什么规划？",
  "conversationId": "{{contextConversationId}}"
}

### Context routing: an explicit new task must override CODING context
# Expected: taskType=LITERARY, modelId=literary
POST {{baseUrl}}/api/agent/route
Content-Type: application/json

{
  "question": "现在换一个任务，请写一首描写夏夜的现代诗。",
  "conversationId": "{{contextConversationId}}"
}

### Semantic router: reusable single-question assertion
# Fill in question, expectedTaskType, and expectedModelId for one item from
# docs/semantic-router-test-questions.md.
# This endpoint only evaluates routing: it does not call a chat model or persist messages.
POST {{baseUrl}}/api/agent/route
Content-Type: application/json

{
  "question": ""
}

> {%
    const expectedTaskType = "CODING";
    const expectedModelId = "coding";

    client.test("semantic route returns HTTP 200", function () {
        client.assert(response.status === 200, "Expected HTTP 200 but got " + response.status);
    });

    client.test("semantic route selects expected task type", function () {
        client.assert(
            response.body.taskType === expectedTaskType,
            "Expected taskType=" + expectedTaskType + " but got " + response.body.taskType
        );
    });

    client.test("semantic route selects expected model", function () {
        client.assert(
            response.body.modelId === expectedModelId,
            "Expected modelId=" + expectedModelId + " but got " + response.body.modelId
        );
    });

    client.test("semantic router handled the request", function () {
        client.assert(
            response.body.reason.startsWith("Semantic router selected"),
            "Rule fallback was used: " + response.body.reason
        );
    });
%}

