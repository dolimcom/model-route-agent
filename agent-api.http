@baseUrl = http://localhost:8080

### Coding model: create an isolated conversation
POST {{baseUrl}}/api/conversations
Content-Type: application/json

{
  "title": "Real coding model verification"
}

> {% client.global.set("codingConversationId", response.body.id); %}

### Coding model: verify routing and real provider response
# Expected: HTTP 200, route.taskType=CODING, route.modelId=coding, no [Mock response]
POST {{baseUrl}}/api/agent/chat
Content-Type: application/json

{
  "question": "请用两句话分析下面 Java 代码的 bug，并给出最小修复方案：String text = null; System.out.println(text.length());",
  "conversationId": "{{codingConversationId}}"
}

### Coding model: verify the user message and assistant answer were persisted
# Expected: two messages; assistant.modelId=coding
GET {{baseUrl}}/api/conversations/{{codingConversationId}}/messages

### Day 10: create a conversation for the natural-language file agent
POST {{baseUrl}}/api/conversations
Content-Type: application/json

{
  "title": "Day 10 natural-language file operation"
}

> {% client.global.set("day10ConversationId", response.body.id); %}

### Day 10: inspect and remember the original test file
# Expected original content:
# Day 10 original content.
# This file has not been modified by the agent.
GET {{baseUrl}}/api/files/agent-workspace/content?path=nested/day10-agent.txt

### Day 10: ask the model to generate a manual file-operation proposal
# Expected: HTTP 201, operationType=UPDATE_FILE, status=PENDING
POST {{baseUrl}}/api/agent/file-operations
Content-Type: application/json

{
  "instruction": "将当前文件改为两行：第一行写 Day 10 agent update completed.，第二行写 This change requires approval.；不要添加其他内容。",
  "conversationId": "{{day10ConversationId}}",
  "rootId": "agent-workspace",
  "selectedPath": "nested/day10-agent.txt",
  "approvalMode": "MANUAL"
}

> {% client.global.set("day10OperationId", response.body.operation.operationId); %}

### Day 10: verify the proposal is waiting for approval
# Expected: the response contains day10OperationId and status=PENDING
GET {{baseUrl}}/api/file-operations?status=PENDING

### Day 10: verify manual mode has not modified the file
# Expected: content is still the original two lines
GET {{baseUrl}}/api/files/agent-workspace/content?path=nested/day10-agent.txt

### Day 10: approve and execute the model-generated operation
# Expected: status=EXECUTED and approvedAt/executedAt are not null
POST {{baseUrl}}/api/file-operations/{{day10OperationId}}/approve

### Day 10: verify the approved content
# Expected exactly two lines requested above
GET {{baseUrl}}/api/files/agent-workspace/content?path=nested/day10-agent.txt

### Day 10: verify conversation history and model routing metadata
# Expected: two messages and the operation response used this conversationId
GET {{baseUrl}}/api/conversations/{{day10ConversationId}}/messages

### Day 10: roll back the model-generated update
# Expected: status=ROLLED_BACK and rolledBackAt is not null
POST {{baseUrl}}/api/file-operations/{{day10OperationId}}/rollback

### Day 10: verify rollback restored the original content
GET {{baseUrl}}/api/files/agent-workspace/content?path=nested/day10-agent.txt
